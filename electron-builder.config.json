{
  "appId": "com.mukyu.ai",
  "productName": "MukyuAI",
  "electronVersion": "42.5.1",
  "directories": {
    "output": "../../dist"
  },
  "files": [
    "**/*"
  ],
  "win": {
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "MukyuAI"
  },
  "mac": {
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  },
  "asar": false
}
